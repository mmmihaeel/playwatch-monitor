{
  "name": "playwatch-monitor",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.17.1",
  "pnpm": {
    "overrides": {
      "@tootallnate/once": "^3.0.1",
      "esbuild": "^0.27.4",
      "fast-xml-parser": "^5.5.7"
    }
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @playwatch/api dev --filter @playwatch/web dev --filter @playwatch/worker dev",
    "audit": "pnpm audit --audit-level moderate",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "test": "node -e \"require('node:fs').mkdirSync('coverage/.tmp', { recursive: true })\" && vitest run --coverage",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate --config packages/db/drizzle.config.ts",
    "db:migrate": "tsx --tsconfig packages/db/tsconfig.typecheck.json packages/db/scripts/migrate.ts",
    "db:seed": "tsx --tsconfig packages/db/tsconfig.typecheck.json packages/db/scripts/seed.ts",
    "check": "pnpm build && pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@swc/core": "^1.11.24",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.6.0",
    "@types/pg": "^8.15.5",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-testing-library": "^7.1.1",
    "globals": "^16.4.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.44.1",
    "vitest": "^3.2.4"
  }
}
